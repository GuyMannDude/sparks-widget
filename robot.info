  "contact": "guy@projectsparks.ai",
  "maintainer": "Project Sparks",

  "capabilities": [
    "Embedded chat widget — drop one `<script src=\"/rocky-widget.js\">` tag on a page and the widget renders itself (button + chat overlay).",
    "Peter persona — cheerful cartoon-lobster mascot with system-prompted product knowledge. Friendly, concise, sticks to verified product info.",
    "Per-visitor memory namespaces via Mnemo — each visitor has their own agent_id slot (peter-widget-<visitor_id>). Peter remembers context across sessions without cross-visitor leakage.",
    "Visitor profile recall — when chat starts, Peter pulls the last 5 memory snippets for that visitor and threads them into context.",
    "Question logging — every visitor question goes into Mnemo with the visitor's namespace so the team can review what people are asking.",
    "Visitor-facing privacy controls — /api/wipe-visitor lets a visitor delete their entire memory namespace on demand (GDPR-shaped right to erasure).",
    "Product knowledge from local file — `~/peter-customer/knowledge/products.md` is loaded at startup; rules in the system prompt suppress products marked '(Retired)'.",
    "Model-routed via Sparks Router — Peter's model choice (`x-ai/grok-4-fast` by default) goes through the router so model swaps are config, not code.",
    "Graceful degradation — if Sparks Router is down, returns a polite 'I'm having a little trouble right now' instead of crashing or hanging."
  ],

  "exposes": {
    "rest_api": {
      "default_port": 50095,
      "base_path": "/",
      "endpoints": [
