        {"path": "/rocky-icon.svg", "method": "GET", "purpose": "Serve Peter's icon."},
        {"path": "/api/chat", "method": "POST", "purpose": "Main chat endpoint. POST {messages, visitor_id}; returns {reply}. Routes through Sparks Router; loads visitor memory from Mnemo before answering."},
        {"path": "/api/save-visitor", "method": "POST", "purpose": "Persist a visitor's profile snippet to their Mnemo namespace. POST {visitor_id, summary, key_facts}."},
        {"path": "/api/log-question", "method": "POST", "purpose": "Log a visitor's question to Mnemo (so the team can review what people ask). POST {visitor_id, question}."},
        {"path": "/api/recall/:visitor_id", "method": "GET", "purpose": "Pull the recent memory snippets for a specific visitor. Used internally + for debugging."},
        {"path": "/api/wipe-visitor", "method": "POST", "purpose": "Erase a visitor's entire memory namespace. Visitor-initiated right-to-erasure. POST {visitor_id}."}
      ]
    },
    "cli": [
      {"command": "node server.js", "purpose": "Start the widget backend on port 50095."},
      {"command": "npm start", "purpose": "Same — invokes node server.js per package.json scripts."}
    ]
  },

