  "robot_info_version": "0.2",

  "name": "Peter Widget",
  "tagline": "Cartoon lobster on your site, powered by your own LLM stack — chat widget with per-visitor memory.",
  "summary": "Peter Widget is the customer-facing chat widget for projectsparks.ai. A cheerful cartoon lobster named Peter answers visitor questions about Project Sparks products. The backend is a small Express server (~210 LOC) that routes chat through Sparks Router for model access and stores per-visitor memory in a dedicated Mnemo instance. Each visitor gets their own memory namespace so Peter remembers context across return visits without bleeding between users. Drop-in widget served from /rocky-widget.js.",
  "version": "1.1.0",
